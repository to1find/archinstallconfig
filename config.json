{
  "additional-repositories": ["multilib"],
  "archinstall-language": "English",
  "audio_config": { "audio": "pipewire" },
  "bootloader": "Systemd-boot",
  "bootloader_config": {
    "bootloader": "Systemd-boot",
    "removable": false,
    "uki": false
  },
  "custom_commands": [],
  "debug": false,
  "disk_config": {
    "config_type": "default_layout",
    "disk_layouts": {
      "/dev/sda": {
        "partitions": [
          { "size": { "unit": "MiB", "value": 1024 }, "type": "efi" },
          { "size": { "unit": "MiB", "value": 8192 }, "type": "swap" },
          { "size": { "unit": "MiB", "value": 0 },    "type": "linux" }
        ],
        "wipe": true
      }
    }
  },
  "disk_encryption": null,
  "hostname": "arch-pc",
  "kernels": ["linux"],
  "locale_config": {
    "kb_layout": "us",
    "sys_enc": "UTF-8",
    "sys_lang": "en_US.UTF-8"
  },
  "mirror_config": {
    "custom_servers": [
        {"url": "https://mirrors.tuna.tsinghua.edu.cn/archlinux/$repo/os/$arch"}
    ],
    "mirror_regions": {
      "China": ["https://mirrors.tuna.tsinghua.edu.cn/archlinux/$repo/os/$arch"]
    },
    "optional_repositories": [],
    "custom_repositories": [
      {
        "name": "archlinuxcn",
        "url": "https://mirrors.tuna.tsinghua.edu.cn/archlinuxcn/$arch",
        "sign_check": "Optional",
        "sign_option": "TrustAll"
      }
    ]
  },
  "network_config": {},
  "no_pkg_lookups": false,
  "ntp": true,
  "offline": false,
  "packages": [
    "base-devel",
    "git",
    "nvim",
    "network-manager-applet",
    "noto-fonts",
    "noto-fonts-cjk",
    "noto-fonts-emoji",
    "fcitx5",
    "fcitx5-chinese-addons",
    "fcitx5-pinyin-zhwiki",
    "fcitx5-im",
    "openssh",
    "htop"
  ],
  "parallel_downloads": 5,
  "profile_config": null,
  "save_config": null,
  "script": "guided",
  "silent": false,
  "swap": true,
  "timezone": "Asia/Shanghai",
  "version": "2.8.1"
}
